# =============================================================================
# Bayi Yönetimi — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# Variables marked REQUIRED must be set for the app to start.
# Variables marked OPTIONAL degrade gracefully when absent.
# =============================================================================

# =============================================================================
# Supabase — REQUIRED
# Get these from: https://supabase.com/dashboard/project/{ref}/settings/api
# =============================================================================

# Your Supabase project URL (e.g. https://abc123.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS.
# NEVER expose this to the browser or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# AI / Anthropic Claude — REQUIRED
# Get from: https://console.anthropic.com/settings/keys
# Used by all 12 agent roles (AgentRunner calls Claude API)
# =============================================================================

ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# Cron Jobs — REQUIRED
# Used to authenticate Vercel Cron requests to /api/cron/daily-briefing
# Set a long random string (e.g. openssl rand -base64 32)
# Also configure in Vercel dashboard: Settings > Environment Variables
# =============================================================================

CRON_SECRET=your-cron-secret

# =============================================================================
# Site URL — OPTIONAL
# Used in password reset emails (auth.ts). Defaults to localhost in dev.
# Set to your production URL on Vercel.
# =============================================================================

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Telegram Bot Tokens — OPTIONAL
# Each agent role has its own Telegram bot for multi-bot support.
# Agents degrade gracefully when tokens are missing (no Telegram messages sent).
#
# Create bots at: https://t.me/BotFather
# Get token from BotFather after creating each bot.
# Register webhook via: POST https://api.telegram.org/bot{TOKEN}/setWebhook
#   with url: https://your-domain.com/api/telegram/{role}
#
# Legacy fallback token (used when route doesn't pass a specific token)
TELEGRAM_BOT_TOKEN=

# Egitimci (Trainer) agent — /api/telegram/egitimci
TELEGRAM_BOT_TOKEN_EGITIMCI=

# Satis Temsilcisi (Sales Representative) agent — /api/telegram/satis
TELEGRAM_BOT_TOKEN_SATIS=

# Muhasebeci (Accountant) agent — /api/telegram/muhasebeci
TELEGRAM_BOT_TOKEN_MUHASEBECI=

# Depo Sorumlusu (Warehouse Manager) agent — /api/telegram/depo-sorumlusu
TELEGRAM_BOT_TOKEN_DEPO_SORUMLUSU=

# Genel Mudur (General Manager) agent — /api/telegram/genel-mudur
TELEGRAM_BOT_TOKEN_GENEL_MUDUR=

# Tahsilat Uzmani (Collections Specialist) agent — /api/telegram/tahsilat-uzmani
TELEGRAM_BOT_TOKEN_TAHSILAT_UZMANI=

# Dagitim Koordinatoru (Distribution Coordinator) agent — /api/telegram/dagitim-koordinatoru
TELEGRAM_BOT_TOKEN_DAGITIM_KOORDINATORU=

# Saha Satis (Field Sales) agent — /api/telegram/saha-satis
TELEGRAM_BOT_TOKEN_SAHA_SATIS=

# Pazarlamaci (Marketing) agent — /api/telegram/pazarlamaci
TELEGRAM_BOT_TOKEN_PAZARLAMACI=

# Urun Yoneticisi (Product Manager) agent — /api/telegram/urun-yoneticisi
TELEGRAM_BOT_TOKEN_URUN_YONETICISI=

# Satin Alma (Purchasing) agent — /api/telegram/satin-alma
TELEGRAM_BOT_TOKEN_SATIN_ALMA=

# Iade Kalite (Returns & Quality) agent — /api/telegram/iade-kalite
TELEGRAM_BOT_TOKEN_IADE_KALITE=

# =============================================================================
# Error Tracking — OPTIONAL
# Sentry DSN for error reporting (Phase 13 Plan 05)
# Get from: Sentry Dashboard -> Settings -> Client Keys -> DSN
# Create project: Sentry Dashboard -> Projects -> Create Project -> Next.js
# Get auth token: Sentry Dashboard -> Settings -> Auth Tokens -> Create New
# =============================================================================

# Server-side DSN (used by sentry.server.config.ts and sentry.edge.config.ts)
SENTRY_DSN=

# Client-side DSN (used by sentry.client.config.ts — safe to expose in browser)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org and project slugs (used by withSentryConfig in next.config.ts)
SENTRY_ORG=
SENTRY_PROJECT=

# Auth token for source map uploads during Vercel build
SENTRY_AUTH_TOKEN=
